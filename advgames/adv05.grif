	@endif
command.8.43
	@comment("Cmd 47 - loo mir")
	@if @herecarry(17) @and @somewhere(22) @then
		@comment("continue")
		@msg(message.18)
		@msg(message.17)
		@msg(message.15)
		@comment("...continued into Cmd 48")
		@swap(value.counter,value.counter.0)
		@get(value.counter)
		@swap(value.counter,value.counter.0)
		@msg(message.16)
		@comment("...continued into Cmd 52")
	@elseif @herecarry(17) @and @nowhere(22) @then
		@msg(message.22)
		@comment("...continued into Cmd 183")
	@elseif @not @herecarry(17) @then
		@msg(message.13)
	@endif
command.8.44
	@comment("Cmd 63 - loo ove")
	@if @ge(value.counter,0) @and @herecarry(44) @then
		@msg(message.40)
		@comment("...continued into Cmd 64")
	@elseif @herecarry(44) @and @le(value.counter,0) @then
		@msg(message.35)
		@msg(message.36)
	@endif
command.8.46
	@comment("Cmd 61 - loo wat")
	@if @herecarry(37) @then
		@msg(message.31)
		@get(value.counter)
		@msg(message.32)
	@endif
command.8.47
	@comment("Cmd 86 - loo via")
	@if @herecarry(42) @and @false(@get(value.flag.6)) @then
		@msg(message.35)
		@msg(message.37)
	@endif
command.8.48
	@comment("Cmd 80 - loo pos")
	@if @herecarry(47) @then
