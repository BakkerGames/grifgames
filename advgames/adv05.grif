// adv05.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@debug("### Going to room $x")
	\n
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room,"\n"))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i,"\n"))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@comment("DECRMNT MINUTES")
	@if @gt(value.counter,0) @then
		@subto(value.counter,1)
	@endif
	@comment("continue")
	@comment("...continued into Cmd 1")
	@if @false(@get(value.flag.1)) @then
		@msg(message.3)
		@set(value.counter,3)
		@swap(value.counter,value.counter.0)
		@set(value.counter,65)
	@endif
	@comment("...continued into Cmd 2")
	@if @false(@get(value.flag.1)) @then
		@msg(message.2)
		@swap(value.counter,value.counter.3)
		@set(value.counter,0)
		@swap(value.counter,value.counter.3)
	@endif
	@comment("...continued into Cmd 3")
	@if @le(value.counter,10) @and @ge(value.counter,1) @and @false(@get(value.flag.2)) @and @not @isroom(18) @and @not @isroom(6) @then
		@msg(message.19)
	@endif
	@comment("...continued into Cmd 4")
	@if @le(value.counter,4) @and @false(@get(value.flag.4)) @and @ge(value.counter,1) @and @false(@get(value.flag.2)) @then
		@msg(message.20)
	@endif
	@comment("...continued into Cmd 5")
	@if @eq(value.counter,1) @then
		@set(value.flag.dark,true)
		@msg(message.21)
		@look
	@endif
background.6
	@if @here(35) @and @isroom(3) @then
		@comment("SHEET OVER LEDGE")
		@swap(item.35.location,item.10.location)
	@endif
background.7
	@if @true(@get(value.flag.4)) @then
		@comment("DEC PILL")
		@swap(value.counter,value.counter.1)
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 8")
		@if @le(value.counter,8) @and @le(value.counter,4) @then
			@msg(message.20)
		@endif
		@comment("...continued into Cmd 9")
		@if @le(value.counter,0) @then
			@set(value.flag.4,false)
		@endif
		@comment("...continued into Cmd 10")
		@swap(value.counter,value.counter.1)
	@endif
background.11
	@if @rand(33) @and @isroom(4) @and @somewhere(7) @then
		@comment("POLE BROKE")
		@msg(message.9)
		@msg(message.10)
		@msg(message.12)
		@goto(22)
	@endif
background.12
	@if @carry(35) @and @isroom(11) @then
		@comment("UNTIE SHEET")
		@sendto(36,0)
		@swap(item.35.location,item.0.location)
		@msg(message.30)
	@endif
background.13
	@if @le(value.counter,0) @and @false(@get(value.flag.4)) @and @not @isroom(22) @then
		@comment("FELL ASLEEP")
		@set(value.flag.2,true)
	@endif
background.14
	@if @rand(25) @and @le(value.counter,0) @and @carry(31) @and @false(@get(value.flag.2)) @and @not @isroom(22) @then
		@comment("BAT AT NITE")
		@msg(message.23)
		@msg(message.28)
	@endif
background.15
	@if @rand(40) @and @le(value.counter,0) @and @not @carry(31) @and @false(@get(value.flag.2)) @and @not @isroom(22) @then
		@comment("BAT BITE AT NITE")
		@msg(message.23)
		@msg(message.29)
		@set(value.flag.2,true)
		@sleep(2000)
	@endif
background.16
	@if @rand(50) @and @isroom(4) @and @herecarry(9) @then
		@comment("BURNT SHEET")
		@msg(message.53)
		@msg(message.12)
		@goto(22)
	@endif
background.17
	@if @true(@get(value.flag.2)) @and @not @isroom(22) @then
		@comment("FELL SLEEP?")
		@comment("continue")
		@goto(7)
		@set(value.flag.3,true)
		@set(value.flag.2,false)
		@comment("...continued into Cmd 18")
		@if @nowhere(14) @then
			@goto(0)
			@sendto(13,21)
			@sendto(12,0)
		@endif
		@comment("...continued into Cmd 19")
		@if @somewhere(16) @and @not @here(16) @then
			@sendto(16,0)
			@set(value.flag.9,true)
		@endif
		@comment("...continued into Cmd 20")
		@sendto(6,0)
		@sendto(7,0)
		@sendto(10,0)
		@sendto(35,0)
		@comment("...continued into Cmd 21")
		@sendto(1,0)
		@sendto(2,2)
		@set(value.counter,65)
		@sendto(55,0)
		@comment("...continued into Cmd 22")
		@if @somewhere(45) @and @not @here(45) @then
			@sendto(45,0)
			@set(value.flag.9,true)
		@endif
		@comment("...continued into Cmd 23")
		@if @somewhere(26) @and @not @here(26) @then
			@sendto(26,13)
			@set(value.flag.9,true)
		@endif
		@comment("...continued into Cmd 24")
		@if @isroom(0) @then
			@goto(1)
			@msg(message.86)
		@endif
		@comment("...continued into Cmd 25")
		@if @true(@get(value.flag.9)) @then
			@set(value.flag.9,false)
			@goto(1)
			@msg(message.57)
		@endif
		@comment("...continued into Cmd 26")
		@goto(1)
		@set(value.flag.dark,false)
		@msg(message.2)
		@drop(0)
		@comment("...continued into Cmd 27")
		@if @herecarry(18) @then
			@set(value.flag.3,false)
			@swap(item.18.location,item.19.location)
			@msg(message.58)
		@endif
		@comment("...continued into Cmd 28")
		@set(value.flag.4,false)
		@sendto(36,0)
		@drop(0)
		@look
	@endif
background.29
	@if @true(@get(value.flag.3)) @then
		@comment("DEC DAYS")
		@set(value.flag.3,false)
		@swap(value.counter,value.counter.0)
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 30")
		@if @le(value.counter,0) @then
			@msg(message.18)
			@msg(message.14)
			@goto(22)
		@endif
		@comment("...continued into Cmd 31")
		@msg(message.18)
		@swap(value.counter,value.counter.0)
		@take(22)
	@endif
background.32
	@if @rand(50) @and @somewhere(27) @and @not @isroom(13) @then
		@comment("CIGARETTE OUT")
		@swap(value.counter,value.counter.2)
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 33")
		@if @eq(value.counter,0) @then
			@sendto(27,0)
			@sendto(28,0)
			@sendto(29,0)
			@sendto(30,0)
		@endif
		@comment("...continued into Cmd 34")
		@if @isroom(6) @and @eq(value.counter,0) @then
			@msg(message.27)
		@endif
		@comment("...continued into Cmd 35")
		@swap(value.counter,value.counter.2)
	@endif
background.36
	@if @isroom(22) @then
		@comment("END GAME")
		@msg(message.44)
		@quit
	@endif
background.37
	@if @rand(30) @and @le(value.counter,25) @and @nowhere(45) @and @not @isroom(9) @and @nowhere(46) @then
		@comment("DELIVER PACKAGE")
		@comment("continue")
		@swap(value.counter,value.counter.0)
		@comment("...continued into Cmd 38")
		@if @eq(value.counter,2) @then
			@sendto(45,9)
			@sendto(65,9)
			@msg(message.42)
		@endif
		@comment("...continued into Cmd 39")
		@swap(value.counter,value.counter.0)
	@endif
background.40
	@if @false(@get(value.flag.1)) @then
		@comment("MORE INTRO")
		@set(value.flag.1,true)
	@endif
background.41
	@if @le(value.counter,1) @and @not @herecarry(9) @then
		@comment("SUNSET?")
		@set(value.flag.dark,true)
		@look
	@endif
background.42
	@if @isroom(10) @and @ge(value.counter,0) @and @true(@get(value.flag.15)) @then
		@comment("LITE DOORLW")
		@set(value.flag.dark,false)
		@look
	@endif
background.43
	@if @rand(29) @and @le(value.counter,39) @and @nowhere(47) @and @not @isroom(9) @then
		@comment("DELIVER POSTCARD")
		@sendto(47,9)
		@msg(message.42)
	@endif
background.intro
	@if @false(@get(system.introdone)) @then
		@modmessages
		@look
		@set(system.introdone,true)
	@endif
command.1.1
	@if @gt(@get(@concat("room.",@room,".exit.n")),0) @then
		@goto(@get(@concat("room.",@room,".exit.n")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.2
	@if @gt(@get(@concat("room.",@room,".exit.s")),0) @then
		@goto(@get(@concat("room.",@room,".exit.s")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.3
	@if @gt(@get(@concat("room.",@room,".exit.e")),0) @then
		@goto(@get(@concat("room.",@room,".exit.e")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.4
	@if @gt(@get(@concat("room.",@room,".exit.w")),0) @then
		@goto(@get(@concat("room.",@room,".exit.w")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.5
	@if @gt(@get(@concat("room.",@room,".exit.u")),0) @then
		@goto(@get(@concat("room.",@room,".exit.u")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.6
	@if @gt(@get(@concat("room.",@room,".exit.d")),0) @then
		@goto(@get(@concat("room.",@room,".exit.d")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.7
	@comment("Cmd 116 - go she")
	@msg(message.50)
command.1.9
	@comment("Cmd 45 - go win")
	@if @isroom(4) @then
		@goto(5)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 46")
	@elseif @isroom(5) @then
		@goto(10)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 55")
	@elseif @here(1) @and @carry(35) @then
		@goto(3)
		@drop(6)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 62")
	@elseif @isroom(3) @and @carry(35) @then
		@goto(2)
		@sendto(6,0)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 112")
	@elseif @isroom(10) @then
		@goto(5)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 202")
	@elseif @here(1) @and @not @carry(35) @then
		@goto(3)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 205")
	@elseif @isroom(3) @and @not @carry(35) @then
		@goto(2)
		@look
		@msg(message.39)
	@endif
command.1.12
	@comment("Cmd 195 - go pol")
	@if @isroom(3) @then
		@msg(message.74)
	@endif
command.1.16
	@comment("Cmd 100 - go roo")
	@if @false(@get(value.flag.8)) @and @false(@get(value.flag.7)) @and @isroom(20) @then
		@goto(12)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 125")
	@elseif @isroom(20) @and @true(@get(value.flag.7)) @then
		@goto(21)
		@look
		@msg(message.39)
		@comment("...continued into Cmd 141")
	@elseif @isroom(20) @and @true(@get(value.flag.8)) @then
		@goto(14)
		@look
		@msg(message.39)
	@endif
command.1.18
	@comment("Cmd 117 - go pit")
	@if @here(32) @then
		@set(value.flag.dark,true)
		@goto(18)
		@look
		@msg(message.39)
	@endif
command.1.19
	@comment("Cmd 155 - go doo")
	@if @here(13) @then
		@goto(7)
		@look
		@msg(message.39)
	@endif
command.1.32
	@comment("Cmd 110 - go pas")
	@if @here(56) @then
		@goto(19)
		@set(value.flag.dark,true)
		@look
		@msg(message.39)
	@endif
command.1.33
	@comment("Cmd 93 - go bed")
	@if @here(34) @then
		@goto(1)
		@look
		@msg(message.39)
	@endif
command.1.34
	@comment("Cmd 176 - go cof")
	@if @here(29) @then
		@goto(13)
		@look
		@msg(message.39)
	@endif
command.1.37
	@comment("Cmd 98 - go dum")
	@if @here(63) @then
		@goto(20)
		@look
		@msg(message.39)
	@endif
command.1.44
	@comment("Cmd 94 - go ove")
	@if @herecarry(44) @and @ge(value.counter,0) @then
		@msg(message.1)
		@msg(message.40)
		@comment("...continued into Cmd 95")
	@elseif @herecarry(44) @and @le(value.counter,0) @then
		@goto(15)
		@look
		@msg(message.39)
	@endif
command.1.50
	@comment("Cmd 124 - go gat")
	@if @here(50) @then
		@msg(message.43)
		@msg(message.44)
		@quit
	@endif
command.1.52
	@comment("Cmd 199 - go ven")
	@msg(message.1)
	@msg(message.76)
command.1.54
	@comment("Cmd 146 - go toi")
	@if @here(62) @then
		@msg(message.39)
		@msg(message.54)
	@endif
command.1.60
	@comment("Cmd 170 - go sle")
	@set(value.flag.2,true)
command.6
	@comment("Cmd 160 - qui")
	@quit
command.7
	@comment("Cmd 131 - unc")
	@if @herecarry(47) @and @nowhere(15) @then
		@take(15)
		@take(51)
		@msg(message.39)
	@endif
command.8
	@comment("Cmd 219 - loo")
	@look
	@msg(message.38)
command.8.5
	@comment("Cmd 171 - loo up")
	@if @isroom(9) @then
		@msg(message.39)
		@msg(message.38)
		@msg(message.64)
		@msg(message.62)
		@comment("...continued into Cmd 173")
	@elseif @here(49) @then
		@msg(message.39)
