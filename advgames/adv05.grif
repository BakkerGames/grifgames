command.8.59
	@comment("Cmd 81 - loo let")
	@if @herecarry(65) @then
		@msg(message.55)
	@endif
command.8.70
	@comment("Cmd 182 - loo nec")
	@script(script.inventory)
command.8.76
	@comment("Cmd 201 - loo dus")
	@if @herecarry(70) @then
		@msg(message.88)
		@msg(message.38)
	@endif
command.8.78
	@comment("Cmd 216 - loo mem")
	@if @herecarry(71) @then
		@msg(message.55)
	@endif
command.10.*
	@set(temp.found,false)
	@foreachlist(x,@concat("nounitem.",@get(input.noun)))
		@if @here($x) @and @false(@get(temp.found)) @then
			@take($x)
			@set(temp.found,true)
			@msg(message.ok)
		@endif
	@endforeachlist
	@if @false(@get(temp.found)) @then
		@msg(message.dont_see)
	@endif
command.10.5
	@comment("Cmd 150 - get up")
	@if @isroom(1) @then
		@goto(2)
		@look
		@msg(message.39)
	@endif
command.10.7
