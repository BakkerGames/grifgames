		@comment("continue")
		@comment("...continued into Cmd 17")
		@if @le(value.counter,0) @then
			@msg(message.28)
			@msg(message.29)
			@sendto(23,11)
		@endif
		@comment("...continued into Cmd 18")
		@if @le(value.counter,0) @then
			@set(value.counter,30)
			@set(temp.swap,@get(value.counter))
			@set(value.counter,@get(value.counter.4))
			@set(value.counter.4,@get(temp.swap))
			@set(value.counter,10)
			@set(temp.swap,@get(value.counter))
			@set(value.counter,@get(value.counter.4))
			@set(value.counter.4,@get(temp.swap))
		@endif
		@comment("...continued into Cmd 19")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
	@endif
