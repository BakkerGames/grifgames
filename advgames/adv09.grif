// adv09.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room,"\n"))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i,"\n"))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@if @rand(3) @and @somewhere(9) @then
		@msg(message.36)
		@swap(item.9.location,item.26.location)
		@look
	@endif
background.1
	@if @here(70) @and @herecarry(9) @then
		@sendto(70,0)
		@look
		@msg(message.10)
		@msg(message.97)
	@endif
background.2
	@if @false(@get(value.flag.1)) @then
		@set(value.counter,0)
		@comment("continue")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@set(value.counter,12)
		@comment("...continued into Cmd 3")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.6))
		@set(value.counter.6,@get(temp.swap))
		@msg(message.3)
		@msg(message.4)
		@comment("...continued into Cmd 4")
		@set(value.flag.1,true)
		@set(value.counter,25)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@set(value.counter,170)
		@comment("...continued into Cmd 5")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.7))
		@set(value.counter.7,@get(temp.swap))
		@goto(24)
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@goto(11)
		@comment("...continued into Cmd 6")
		@set(value.counter,1)
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap.1))
		@set(value.locationswap.1,@get(temp.swap))
		@goto(1)
	@endif
background.7
	@addto(value.counter,1)
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.7))
	@set(value.counter.7,@get(temp.swap))
	@comment("continue")
	@if @gt(value.counter,0) @then
		@subto(value.counter,1)
	@endif
	@comment("...continued into Cmd 8")
	@if @le(value.counter,25) @and @false(@get(value.flag.15)) @and @ge(value.counter,0) @then
		@msg(message.54)
		@msg(message.70)
	@endif
	@comment("...continued into Cmd 9")
	@if @le(value.counter,0) @and @false(@get(value.flag.17)) @then
		@msg(message.55)
		@set(value.flag.dark,true)
		@look
		@set(value.flag.17,true)
	@endif
	@comment("...continued into Cmd 10")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.7))
	@set(value.counter.7,@get(temp.swap))
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.3))
	@set(value.counter.3,@get(temp.swap))
	@if @gt(value.counter,0) @then
		@subto(value.counter,1)
	@endif
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.3))
	@set(value.counter.3,@get(temp.swap))
	@comment("...continued into Cmd 11")
	@if @isroom(10) @and @false(@get(value.flag.17)) @then
		@set(value.flag.dark,false)
		@look
	@endif
background.12
	@if @true(@get(value.flag.17)) @and @nowhere(70) @and @isroom(11) @and @not @herecarry(9) @then
		@drop(70)
	@endif
