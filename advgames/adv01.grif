command.10.*
	@set(_found,false)
	@foreachlist(x,@concat("nounitem.",@get(input.noun)))
		@if @here($x) @and @false(@get(_found)) @then
			@take($x)
			@set(_found,true)
			@msg(message.ok)
		@endif
	@endforeachlist
	@if @false(@get(_found)) @then
		@msg(message.dont_see)
	@endif
