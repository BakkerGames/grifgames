// adv07.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@debug("### Going to room $x")
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(_count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(_count,1)
		@endif
	@endfor
	@write(@get(_count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(_found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(_found)) @then
					@nl
					@msg(message.also_see)
					@set(_found,true)
				@endif
				@debug(@concat("### ITEM #",$i))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@if @false(@get(value.flag.1)) @then
		@comment("INTRO")
		@set(value.counter,600)
		@set(value.flag.1,true)
		@msg(message.18)
		@script(script.inventory)
	@endif
background.1
	@if @ge(@get(value.counter),0) @then
		@comment("DECREMENT COUNTER")
		@if @gt(@get(value.counter),0) @then
			@subto(value.counter,1)
		@endif
	@endif
background.2
	@if @le(@get(value.counter),40) @then
		@comment("PARK IS CLOSING")
		@msg(message.16)
		@get(value.counter)
		@msg(message.17)
	@endif
background.3
	@if @rand(40) @and @isroom(3) @and @false(@get(value.flag.7)) @then
		@comment("AIR BLAST")
		@msg(message.88)
	@endif
background.4
	@if @isroom(10) @and @false(@get(value.flag.5)) @then
		@comment("WALL CLOSES")
		@set(value.flag.5,true)
		@msg(message.84)
	@endif
background.5
	@if @not @isroom(10) @then
		@comment("WALL RESET")
		@set(value.flag.5,false)
	@endif
background.6
	@if @rand(5) @and @herecarry(4) @and @nowhere(24) @then
		@comment("HEEL LOOSE")
		@msg(message.71)
	@endif
background.7
	@if @isroom(4) @and @false(@get(value.flag.5)) @then
		@comment("WALL")
		@set(value.flag.5,true)
	@endif
background.8
	@if @isroom(2) @then
		@comment("AUTHORIZE")
		@set(value.flag.4,false)
	@endif
background.9
	@if @here(31) @then
		@comment("LOUD CALIOPE")
		@msg(message.42)
	@endif
background.10
	@if @rand(40) @and @isroom(3) @and @true(@get(value.flag.7)) @then
		@comment("AIR BLAST HARD")
		@msg(message.89)
		@set(value.flag.dark,false)
		@goto(35)
	@endif
background.11
	@if @le(@get(value.counter),0) @and @false(@get(value.flag.4)) @then
		@comment("CLOSE PARK")
		@msg(message.10)
		@goto(1)
		@look
	@endif
background.12
	@if @here(68) @and @isroom(1) @then
		@comment("DOLLAR BILL")
		@sendto(68,0)
		@msg(message.5)
	@endif
background.13
	@if @not @carry(4) @and @isroom(2) @then
		@comment("NO SHOES THROWN OUT")
		@sleep(2000)
		@sleep(2000)
		@msg(message.10)
		@goto(1)
	@endif
background.14
	@if @not @carry(23) @and @isroom(2) @then
		@comment("NO TICKET THROW OUT")
		@sleep(2000)
		@sleep(2000)
		@msg(message.10)
		@goto(1)
	@endif
background.15
	@if @here(28) @and @here(27) @then
		@comment("COMB")
		@swap(item.59.location,item.52.location)
		@msg(message.19)
		@sendto(28,0)
	@endif
background.16
	@if @somewhere(59) @and @not @here(59) @then
		@comment("REMOVE STAIR")
		@swap(item.59.location,item.52.location)
	@endif
background.17
	@if @isroom(35) @then
		@comment("PERSON IN ROOM END GAME")
		@quit
	@endif
background.18
	@if @here(54) @and @isroom(1) @then
		@comment("GIVE DOLLAR")
		@msg(message.49)
		@sendto(54,0)
		@take(23)
	@endif
background.19
	@if @rand(25) @and @isroom(22) @and @nowhere(1) @then
		@comment("HEMP FALL")
		@msg(message.44)
	@endif
background.20
	@if @here(35) @and @here(33) @then
		@comment("VALVE")
		@drop(34)
		@sendto(35,0)
	@endif
background.21
	@if @here(57) @and @somewhere(37) @and @not @here(37) @then
		@comment("FUSE GUM")
