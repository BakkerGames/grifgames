background.24
	@if @isroom(25) @then
		@comment("SHOOTING GALLERY")
		@goto(14)
		@comment("continue")
		@comment("...continued into Cmd 25")
		@if @not @here(64) @then
			@msg(message.68)
			@msg(message.30)
			@goto(25)
			@quit
		@endif
		@comment("...continued into Cmd 26")
		@goto(25)
	@endif
background.27
	@if @carry(67) @then
		@comment("WON")
		@msg(message.91)
		@quit
	@endif
background.28
	@if @isroom(34) @and @false(@get(value.flag.15)) @then
		@comment("DARK")
		@set(value.flag.dark,true)
		@look
	@endif
background.29
	@if @isroom(26) @and @true(@get(value.flag.15)) @then
		@comment("LIGHT")
		@set(value.flag.dark,false)
		@look
	@endif
