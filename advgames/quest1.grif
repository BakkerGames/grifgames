script.intro1
	@set(_yorn,@getinchannel)
	@if @true(@get(_yorn)) @then
		@writeline("\nDo you want to restore the saved game?")
		@setoutchannel("#ASK;")
		@setoutchannel("@script(script.intro2)")
	@else
		@script(script.intro3)
	@endif
script.intro2
	@set(_yorn,@getinchannel)
	@if @true(@get(_yorn)) @then
		@setoutchannel("#RESTORE;")
		@setoutchannel("@script(script.intro3)")
	@else
		@script(script.intro3)
	@endif
script.intro3
	@modmessages
	@look
	@set(system.introdone,true)
script.inventory
	@msg(message.carrying)
	@set(_found,false)
	@for(i,0,@get(system.itemcount))
		@if @carry($i) @then
			@if @false(@get(_found)) @then
				@set(_found,true)
			@endif
			@debug(@concat("### ITEM #",$i))
			@msg(item.$i.longdesc)
		@endif
	@endfor
	@if @false(@get(_found)) @then
		@msg(message.nothing)
	@endif
script.restore
	@setoutchannel("#RESTORE;")
	@setoutchannel("@msg(message.ok) @nl @look")
script.save
	@setoutchannel("#SAVE;")
	@setoutchannel("@msg(message.1024)")
script.score
	@set(_count,0)
	@for(x,1,@get(system.itemcount))
		@if @true(@get(item.$x.treasure)) @and @eq(@get(item.$x.location),@get(value.treasureroom)) @then
			@addto(_count,1)
		@endif
	@endfor
	@write(@format(@get(message.score),@get(_count)))
	@nl
	@set(_percent,@div(@mul(@get(_count),100),@get(value.treasurecount)))
	@write(@format(@get(message.percent_complete),@get(_percent)))
	@nl
	@if @eq(@get(_count),@get(value.treasurecount)) @then
		@msg(message.well_done)
		@quit
	@endif
