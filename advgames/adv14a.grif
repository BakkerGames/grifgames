command.10.30
	@comment("Cmd 94 - get brea")
	@if @isfalse(@get(value.flag.6)) @then
		@msg(message.1)
		@set(value.flag.6,true)
		@comment("continue")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@comment("...continued into Cmd 95")
