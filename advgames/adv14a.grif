command.1.9
	@comment("Cmd 229 - go ledg")
	@msg(message.44)
command.1.10
	@comment("Cmd 126 - go hill")
	@if @isroom(5) @then
		@msg(message.1)
		@goto(6)
		@look
		@comment("...continued into Cmd 228")
	@elseif @isroom(7) @then
		@msg(message.3)
		@msg(message.46)
	@endif
command.1.11
	@comment("Cmd 85 - go ship")
	@if @here(43) @then
		@goto(4)
		@look
		@set(value.flag.7,false)
		@comment("...continued into Cmd 154")
	@elseif @here(29) @then
		@sendto(29,0)
		@goto(13)
		@set(value.flag.5,false)
		@set(value.flag.7,false)
		@comment("...continued into Cmd 155")
	@elseif @here(28) @then
		@sendto(28,0)
		@goto(4)
		@set(value.flag.5,false)
		@set(value.flag.7,false)
		@comment("...continued into Cmd 199")
	@elseif @here(63) @then
