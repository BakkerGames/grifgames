	@if @istrue(@get(value.flag.13)) @and @istrue(@get(value.flag.4)) @and @nowhere(32) @and @isroom(12) @then
		@drop(63)
		@look
	@endif
background.31
	@if @istrue(@get(value.flag.23)) @and @carry(18) @then
