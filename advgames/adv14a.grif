	@if @istrue(@get(value.flag.5)) @and @carry(56) @then
		@swap(item.62.location,item.56.location)
	@endif
background.34
	@if @rand(15) @and @istrue(@get(value.flag.2)) @and @isroom(1) @then
		@msg(message.42)
	@endif
background.35
	@if @istrue(@get(value.flag.4)) @and @isfalse(@get(value.flag.6)) @then
		@msg(message.16)
		@set(value.flag.dark,false)
		@goto(24)
	@endif
background.36
	@if @not @carry(1) @and @carry(2) @then
		@sendto(2,0)
		@set(value.flag.2,true)
		@set(value.flag.18,false)
	@endif
background.37
	@if @not @carry(17) @and @carry(18) @then
		@sendto(18,0)
		@set(value.flag.2,true)
		@set(value.flag.18,false)
	@endif
background.38
	@if @isfalse(@get(value.flag.18)) @and @istrue(@get(value.flag.3)) @then
		@set(value.flag.dark,true)
		@set(value.flag.18,true)
		@look
	@endif
background.39
	@if @isfalse(@get(value.flag.19)) @and @isfalse(@get(value.flag.7)) @then
		@msg(message.32)
		@msg(message.33)
	@endif
background.40
	@if @istrue(@get(value.flag.2)) @then
		@msg(message.4)
		@msg(message.5)
	@endif
background.41
	@if @istrue(@get(value.flag.18)) @and @isfalse(@get(value.flag.2)) @and @isfalse(@get(value.flag.3)) @then
		@set(value.flag.dark,false)
		@set(value.flag.18,false)
		@look
	@endif
background.42
	@if @isfalse(@get(value.flag.18)) @and @istrue(@get(value.flag.2)) @then
		@set(value.flag.dark,true)
		@set(value.flag.18,true)
		@look
	@endif
background.43
	@if @rand(25) @and @istrue(@get(value.flag.4)) @and @istrue(@get(value.flag.20)) @then
		@set(value.flag.20,false)
		@set(value.flag.13,true)
	@endif
background.44
	@if @istrue(@get(value.flag.29)) @and @le(value.counter,0) @then
		@set(value.flag.29,false)
		@set(value.counter,0)
	@endif
background.45
	@if @le(value.counter,6) @then
		@set(value.flag.27,true)
	@endif
background.46
	@if @ge(value.counter,6) @and @nowhere(46) @then
		@set(value.flag.27,false)
	@endif
background.47
	@if @isroom(24) @then
		@quit
	@endif
background.48
	@if @istrue(@get(value.flag.28)) @then
		@set(value.counter,20)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 49")
		@if @le(value.counter,0) @then
			@set(value.flag.28,false)
			@set(value.counter,0)
		@endif
		@comment("...continued into Cmd 50")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
	@endif
background.intro
	@if @false(@get(system.introdone)) @then
		@modmessages
		@look
		@set(system.introdone,true)
	@endif
command.1.1
	@if @gt(@get(@concat("room.",@room,".exit.n")),0) @then
		@goto(@get(@concat("room.",@room,".exit.n")))
		@look
	@else
		@msg(message.cant_go)
	@endif
command.1.2
