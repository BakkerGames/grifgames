		@goto(23)
		@look
	@endif
command.1.13
	@comment("Cmd 109 - go crac")
	@if @isroom(7) @then
		@set(value.flag.dark,true)
		@goto(8)
		@set(value.flag.3,true)
		@set(value.flag.16,true)
		@comment("...continued into Cmd 110")
	@elseif @isroom(8) @then
		@goto(7)
		@set(value.flag.3,false)
		@set(value.flag.16,false)
		@look
	@endif
command.1.16
	@comment("Cmd 214 - go craw")
