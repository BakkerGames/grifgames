// adv14a.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room,"\n"))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i,"\n"))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@if @istrue(@get(value.flag.3)) @and @istrue(@get(value.flag.29)) @and @isfalse(@get(value.flag.16)) @then
		@set(value.flag.3,false)
		@set(value.flag.31,true)
	@endif
background.1
	@if @istrue(@get(value.flag.31)) @and @isfalse(@get(value.flag.29)) @then
		@set(value.flag.3,true)
		@set(value.flag.31,false)
	@endif
background.2
	@if @istrue(@get(value.flag.29)) @and @ge(value.counter,0) @then
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
	@endif
background.3
	@if @istrue(@get(value.flag.4)) @and @carry(10) @then
		@sendto(10,14)
	@endif
background.4
	@if @isfalse(@get(value.flag.2)) @and @isfalse(@get(value.flag.3)) @then
		@set(value.flag.dark,false)
	@endif
background.5
	@if @rand(8) @and @isfalse(@get(value.flag.21)) @and @carry(18) @and @isfalse(@get(value.flag.22)) @then
		@set(value.flag.22,true)
		@set(value.flag.18,false)
	@endif
background.6
	@if @carry(67) @and @isfalse(@get(value.flag.5)) @then
		@swap(item.67.location,item.68.location)
	@endif
background.7
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.1))
	@set(value.counter.1,@get(temp.swap))
	@addto(value.counter,1)
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.1))
	@set(value.counter.1,@get(temp.swap))
background.8
	@if @isfalse(@get(value.flag.1)) @then
		@set(value.counter,40)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@comment("continue")
		@comment("...continued into Cmd 9")
		@set(value.flag.dark,true)
		@look
		@msg(message.2)
		@comment("...continued into Cmd 10")
		@set(value.flag.1,true)
		@set(value.flag.2,true)
		@set(value.flag.18,true)
		@msg(message.63)
		@comment("...continued into Cmd 11")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
		@set(value.counter,0)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
		@set(value.counter,20)
	@endif
background.12
	@if @isroom(13) @and @here(42) @then
		@set(value.flag.25,true)
	@endif
background.13
	@if @istrue(@get(value.flag.5)) @and @carry(12) @then
		@set(value.flag.24,true)
	@endif
background.14
	@if @istrue(@get(value.flag.5)) @and @carry(14) @then
		@set(value.flag.24,true)
	@endif
background.15
	@if @istrue(@get(value.flag.5)) @and @carry(51) @then
		@set(value.flag.24,true)
	@endif
background.16
	@if @istrue(@get(value.flag.24)) @and @somewhere(51) @and @nowhere(50) @then
		@swap(item.50.location,item.51.location)
	@endif
background.17
	@if @herecarry(17) @and @not @carry(18) @and @istrue(@get(value.flag.4)) @then
		@set(value.flag.22,false)
		@set(value.flag.23,true)
	@endif
background.18
	@if @carry(31) @then
		@set(value.flag.19,true)
	@endif
background.19
	@if @isroom(13) @and @not @here(42) @then
		@set(value.flag.25,false)
	@endif
background.20
	@if @isfalse(@get(value.flag.13)) @and @somewhere(63) @then
		@sendto(63,0)
		@look
	@endif
background.21
	@if @istrue(@get(value.flag.6)) @then
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@subto(value.counter,1)
		@comment("continue")
		@comment("...continued into Cmd 22")
		@if @le(value.counter,3) @then
			@msg(message.15)
		@endif
		@comment("...continued into Cmd 23")
		@if @le(value.counter,0) @and @isfalse(@get(value.flag.4)) @then
			@msg(message.17)
			@set(value.flag.6,false)
			@set(value.flag.17,false)
		@endif
		@comment("...continued into Cmd 24")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
	@endif
background.25
	@if @istrue(@get(value.flag.4)) @and @carry(2) @then
		@sendto(2,0)
		@set(value.flag.2,true)
		@set(value.flag.18,false)
		@comment("continue")
		@comment("...continued into Cmd 26")
		@msg(message.24)
	@endif
background.27
	@if @isfalse(@get(value.flag.4)) @then
		@set(value.flag.10,false)
		@set(value.flag.11,false)
		@set(value.flag.12,false)
		@set(value.flag.13,false)
	@endif
background.28
	@if @isfalse(@get(value.flag.4)) @then
