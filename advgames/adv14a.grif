command.1.43
	@comment("Cmd 60 - go port")
	@if @somewhere(48) @and @gt(@invcount,0) @and @not @carry(2) @then
		@msg(message.3)
		@msg(message.26)
		@msg(message.10)
		@msg(message.61)
		@comment("...continued into Cmd 65")
	@elseif @isroom(19) @and @eq(@invcount,0) @then
		@msg(message.1)
		@goto(2)
		@look
		@comment("...continued into Cmd 66")
	@elseif @here(48) @and @eq(@invcount,0) @then
		@msg(message.1)
		@goto(19)
		@look
