// adv13.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room,"\n"))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i,"\n"))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@if @isroom(19) @and @false(@get(value.flag.15)) @then
		@comment("IN TREE")
		@set(value.flag.dark,true)
		@look
	@endif
background.1
	@if @isroom(23) @and @not @here(47) @and @false(@get(value.flag.15)) @then
		@comment("IN BOX")
		@set(value.flag.dark,true)
		@look
	@endif
background.2
	@if @true(@get(value.flag.15)) @and @not @isroom(23) @and @not @isroom(19) @and @not @isroom(12) @then
		@comment("NOT DARK")
		@set(value.flag.dark,false)
		@look
	@endif
background.3
	@if @true(@get(value.flag.8)) @and @not @carry(51) @then
		@comment("WATER FOUNTAIN")
		@take(51)
	@endif
background.4
	@if @rand(50) @and @carry(51) @then
		@comment("FNTN YOUTH")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
		@subto(value.counter,11)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
	@endif
background.5
	@if @rand(50) @and @true(@get(value.flag.7)) @then
		@comment("ELDER SPELL")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 6")
		@if @le(value.counter,0) @then
			@set(value.flag.7,false)
		@endif
		@comment("...continued into Cmd 7")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
		@addto(value.counter,19)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
	@endif
background.8
	@if @isroom(17) @and @herecarry(65) @then
		@comment("WET TOWEL")
		@swap(item.65.location,item.62.location)
	@endif
background.9
	@if @here(29) @and @false(@get(value.flag.15)) @then
		@comment("IN CELL DARK")
		@set(value.flag.dark,true)
		@look
	@endif
background.10
	@if @false(@get(value.flag.1)) @then
		@comment("INTRO")
		@set(value.flag.1,true)
		@msg(message.13)
		@set(value.counter,31)
		@comment("continue")
		@comment("...continued into Cmd 11")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@goto(1)
		@comment("...continued into Cmd 12")
		@set(value.counter,10)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@set(value.counter,30)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@comment("...continued into Cmd 13")
		@set(value.counter,6)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
		@set(value.counter,15)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.7))
		@set(value.counter.7,@get(temp.swap))
		@comment("...continued into Cmd 14")
		@goto(22)
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap.1))
		@set(value.locationswap.1,@get(temp.swap))
		@goto(1)
	@endif
