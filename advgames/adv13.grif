	@set(value.counter,@get(value.counter.4))
	@set(value.counter.4,@get(temp.swap))
	@comment("continue")
	@sendto(52,0)
	@comment("...continued into Cmd 21")
	@if @le(value.counter,0) @then
		@set(value.flag.dark,false)
		@goto(32)
	@endif
	@comment("...continued into Cmd 22")
	@if @ge(value.counter,100) @then
