	@endif
	@comment("...continued into Cmd 23")
	@if @ge(value.counter,60) @and @le(value.counter,100) @then
		@take(52)
		@msg(message.39)
		@msg(message.48)
	@endif
	@comment("...continued into Cmd 24")
	@if @le(value.counter,20) @and @ge(value.counter,0) @then
		@msg(message.48)
	@endif
	@comment("...continued into Cmd 25")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.4))
	@set(value.counter.4,@get(temp.swap))
