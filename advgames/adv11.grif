	@if @rand(8) @and @true(@get(value.flag.11)) @and @false(@get(value.flag.10)) @and @herecarry(12) @then
		@comment("CAVEMAN")
		@msg(message.31)
		@msg(message.33)
		@msg(message.30)
		@set(value.flag.dark,false)
		@goto(30)
	@endif
background.24
	@if @false(@get(value.flag.11)) @and @herecarry(12) @then
