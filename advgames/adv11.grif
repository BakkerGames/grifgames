// adv11.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@debug("### Going to room $x")
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@if @true(@get(value.flag.21)) @then
		@comment("AIR NOW GOOD")
		@set(value.flag.7,false)
	@endif
background.1
	@if @isroom(24) @then
		@comment("LIFEBOAT AIR")
		@set(value.flag.7,true)
	@endif
background.2
	@if @isroom(9) @and @somewhere(47) @and @true(@get(value.flag.21)) @then
		@comment("GOOD AIR")
		@set(value.flag.7,false)
	@endif
background.3
	@if @true(@get(value.flag.1)) @and @false(@get(value.flag.2)) @then
		@comment("no pass")
		@msg(message.10)
		@quit
	@endif
background.4
	@if @false(@get(value.flag.1)) @then
		@comment("start")
		@msg(message.2)
		@set(value.flag.1,true)
		@msg(message.8)
		@msg(message.11)
	@endif
background.5
	@if @isroom(18) @and @herecarry(34) @then
		@comment("BLOCK SWAP")
		@swap(item.35.location,item.34.location)
		@set(value.flag.26,true)
	@endif
background.6
	@if @isroom(8) @and @herecarry(34) @then
		@comment("BLOCK SWAP")
		@swap(item.35.location,item.34.location)
		@set(value.flag.26,true)
	@endif
background.7
	@if @isroom(1) @and @herecarry(34) @then
		@comment("BLOCK SWAP")
		@swap(item.35.location,item.34.location)
		@set(value.flag.26,true)
	@endif
background.8
	@if @isroom(11) @and @herecarry(34) @then
		@comment("BLOCK SWAP")
		@swap(item.35.location,item.34.location)
		@set(value.flag.26,true)
	@endif
background.9
	@if @true(@get(value.flag.26)) @then
		@comment("SET BLK CNTR")
		@set(value.flag.26,false)
		@swap(value.counter,value.counter.3)
		@set(value.counter,5)
		@swap(value.counter,value.counter.3)
	@endif
background.10
	@if @carry(40) @then
		@comment("MEDICINE BALL")
		@msg(message.24)
	@endif
background.11
	@if @not @carry(7) @and @carry(8) @then
		@comment("REMOVE ABND")
		@sendto(8,0)
	@endif
background.12
	@if @true(@get(value.flag.18)) @then
		@comment("breathe out")
		@swap(value.counter,value.counter.1)
		@if @gt(@get(value.counter),0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 13")
		@if @le(@get(value.counter),2) @then
			@msg(message.24)
		@endif
		@comment("...continued into Cmd 14")
		@if @le(@get(value.counter),0) @and @true(@get(value.flag.7)) @then
			@set(value.flag.6,false)
			@set(value.flag.18,false)
			@sleep(2000)
			@sleep(2000)
		@endif
		@comment("...continued into Cmd 15")
		@if @false(@get(value.flag.18)) @then
			@sleep(2000)
			@sleep(2000)
			@msg(message.25)
			@set(value.flag.dark,false)
			@goto(30)
		@endif
		@comment("...continued into Cmd 16")
		@if @le(@get(value.counter),0) @and @true(@get(value.flag.18)) @and @false(@get(value.flag.7)) @then
			@msg(message.26)
			@set(value.flag.5,false)
			@set(value.flag.18,false)
		@endif
		@comment("...continued into Cmd 17")
		@swap(value.counter,value.counter.1)
	@endif
background.18
	@if @isroom(10) @and @true(@get(value.flag.21)) @and @somewhere(47) @then
		@comment("HURRICANE")
		@msg(message.74)
		@msg(message.75)
		@set(value.flag.dark,false)
		@goto(30)
		@msg(message.19)
	@endif
background.19
	@if @true(@get(value.flag.6)) @and @true(@get(value.flag.7)) @and @false(@get(value.flag.5)) @then
		@msg(message.22)
		@sleep(2000)
		@sleep(2000)
		@comment("continue")
		@comment("...continued into Cmd 20")
		@sleep(2000)
		@sleep(2000)
		@msg(message.23)
		@set(value.flag.dark,false)
		@goto(30)
	@endif
background.21
	@if @true(@get(value.flag.7)) @then
