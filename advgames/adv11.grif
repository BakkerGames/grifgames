command.1.11
	@comment("Cmd 74 - go fiel")
	@if @here(2) @and @isroom(18) @then
		@goto(2)
		@drop(2)
		@set(value.flag.7,true)
		@comment("continue")
		@comment("...continued into Cmd 75")
		@if @herecarry(35) @then
			@set(value.flag.27,false)
		@endif
		@comment("...continued into Cmd 76")
	@elseif @herecarry(39) @then
		@msg(message.40)
		@msg(message.62)
		@comment("...continued into Cmd 77")
	@elseif @true(@get(value.flag.24)) @and @isroom(2) @then
		@goto(18)
		@drop(2)
		@set(value.flag.7,false)
		@comment("continue")
		@comment("...continued into Cmd 78")
		@if @herecarry(34) @then
			@set(value.flag.27,true)
		@endif
		@comment("...continued into Cmd 79")
	@elseif @false(@get(value.flag.24)) @and @isroom(2) @then
		@comment("GOT BLOCK?")
		@goto(1)
		@drop(2)
		@set(value.flag.7,false)
		@comment("continue")
		@comment("...continued into Cmd 80")
		@if @herecarry(34) @then
			@set(value.flag.27,true)
		@endif
		@comment("...continued into Cmd 81")
	@elseif @here(19) @and @false(@get(value.flag.15)) @then
		@msg(message.16)
		@msg(message.46)
		@comment("...continued into Cmd 82")
	@elseif @here(15) @and @isroom(10) @then
		@goto(11)
		@drop(15)
		@set(value.flag.7,false)
		@look
		@comment("...continued into Cmd 83")
	@elseif @here(15) @and @isroom(11) @then
		@goto(10)
		@drop(15)
		@set(value.flag.7,true)
		@look
		@comment("...continued into Cmd 86")
	@elseif @here(6) @and @isroom(4) @then
		@goto(8)
		@drop(6)
		@set(value.flag.7,false)
		@look
		@comment("...continued into Cmd 87")
	@elseif @here(6) @and @isroom(8) @then
		@goto(4)
		@drop(6)
		@set(value.flag.7,true)
		@look
		@comment("...continued into Cmd 96")
	@elseif @here(2) @and @isroom(1) @then
		@goto(2)
		@drop(2)
		@set(value.flag.7,true)
		@comment("continue")
		@comment("...continued into Cmd 97")
		@if @herecarry(35) @then
			@set(value.flag.27,false)
		@endif
		@comment("...continued into Cmd 230")
	@elseif @here(47) @and @isroom(9) @then
		@msg(message.1)
		@goto(24)
		@drop(46)
		@drop(47)
		@comment("...continued into Cmd 231")
	@elseif @here(47) @and @isroom(24) @then
		@msg(message.1)
		@goto(9)
		@drop(46)
		@drop(47)
		@comment("...continued into Cmd 232")
	@elseif @not @here(47) @and @isroom(9) @then
		@msg(message.1)
		@goto(24)
		@drop(46)
		@comment("...continued into Cmd 233")
	@elseif @not @here(47) @and @isroom(24) @then
		@msg(message.1)
		@goto(9)
		@drop(46)
	@endif
