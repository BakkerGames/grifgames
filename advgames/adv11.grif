		@endif
		@comment("...continued into Cmd 28")
		@swap(value.counter,value.counter.2)
	@endif
background.29
	@if @rand(50) @and @not @isroom(13) @and @somewhere(12) @and @false(@get(value.flag.10)) @and @nowhere(10) @then
		@comment("CAVE FOLLOWS")
		@drop(12)
	@endif
