		@set(value.flag.11,true)
	@endif
background.25
	@if @true(@get(value.flag.10)) @then
		@comment("CAVE COUNT")
		@set(value.flag.11,false)
		@swap(value.counter,value.counter.2)
		@if @gt(@get(value.counter),0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 26")
		@if @le(@get(value.counter),4) @and @herecarry(12) @then
			@msg(message.31)
			@msg(message.30)
			@msg(message.34)
		@endif
		@comment("...continued into Cmd 27")
		@if @le(@get(value.counter),0) @then
