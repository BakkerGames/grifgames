background.53
	@if @rand(2) @and @istrue(@get(value.flag.4)) @and @nowhere(28) @and @nowhere(29) @then
		@comment("TREE DOWN")
		@sendto(28,4)
		@msg(message.43)
	@endif
background.54
	@if @here(6) @and @here(4) @then
		@comment("PIRATE RUM")
		@swap(item.40.location,item.6.location)
		@comment("continue")
		@drop(41)
		@msg(message.62)
		@comment("...continued into Cmd 55")
		@sendto(4,0)
		@sendto(5,0)
	@endif
background.56
	@if @rand(5) @and @istrue(@get(value.flag.4)) @and @not @carry(28) @and @here(31) @and @not @carry(25) @then
		@comment("STORM DEAD")
		@msg(message.56)
		@msg(message.66)
		@msg(message.11)
		@set(value.flag.dark,false)
		@goto(34)
	@endif
background.57
	@if @isroom(12) @and @gt(@invcount,0) @and @not @carry(25) @and @not @carry(28) @then
		@comment("NO LOG")
		@comment("continue")
		@comment("...continued into Cmd 58")
