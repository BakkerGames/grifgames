		@set(value.counter.4,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 33")
		@if @le(value.counter,2) @then
			@msg(message.45)
		@endif
		@comment("...continued into Cmd 34")
		@if @le(value.counter,0) @then
			@set(value.flag.7,false)
			@msg(message.41)
		@endif
		@comment("...continued into Cmd 35")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
		@comment("...continued into Cmd 36")
	@endif
background.37
	@if @carry(28) @and @carry(25) @then
		@comment("DROP LOG")
		@msg(message.19)
		@msg(message.40)
		@drop(28)
	@endif
background.38
	@if @rand(25) @and @istrue(@get(value.flag.4)) @and @nowhere(25) @and @nowhere(29) @then
