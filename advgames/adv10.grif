		@msg(message.99)
		@comment("continue")
		@comment("...continued into Cmd 42")
		@if @not @herecarry(41) @then
			@set(value.counter,474)
			@get(value.counter)
			@msg(message.59)
			@quit
		@endif
		@comment("...continued into Cmd 43")
		@if @herecarry(41) @then
			@set(value.counter,123)
			@get(value.counter)
			@msg(message.59)
			@quit
		@endif
	@endif
background.44
	@if @istrue(@get(value.flag.10)) @then
		@comment("RAFT LASTING")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 45")
		@if @le(value.counter,10) @then
			@msg(message.52)
		@endif
		@comment("...continued into Cmd 46")
		@if @le(value.counter,0) @then
			@msg(message.43)
			@msg(message.34)
			@msg(message.15)
			@set(value.flag.dark,false)
			@goto(34)
		@endif
		@comment("...continued into Cmd 47")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
	@endif
background.48
	@if @rand(30) @and @here(20) @and @isfalse(@get(value.flag.5)) @then
