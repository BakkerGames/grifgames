// adv10.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room,"\n"))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i,"\n"))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.0
	@comment("moves")
	@addto(value.counter,1)
background.1
	@if @rand(10) @and @somewhere(11) @and @isfalse(@get(value.flag.2)) @then
		@comment("evaporate")
		@sendto(11,0)
		@comment("continue")
		@comment("...continued into Cmd 2")
		@if @istrue(@get(value.flag.1)) @then
			@sendto(10,3)
			@set(value.flag.1,false)
		@endif
	@endif
background.3
	@if @istrue(@get(value.flag.4)) @and @not @here(31) @and @isfalse(@get(value.flag.17)) @and @isfalse(@get(value.flag.18)) @and @not @isroom(13) @then
		@comment("WIND")
		@comment("continue")
		@comment("...continued into Cmd 4")
		@drop(31)
	@endif
background.5
	@if @isfalse(@get(value.flag.3)) @then
		@comment("start")
		@set(value.flag.3,true)
		@comment("continue")
		@set(value.counter,250)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
		@comment("...continued into Cmd 6")
		@set(value.counter,70)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@set(value.counter,300)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@comment("...continued into Cmd 7")
		@set(value.counter,0)
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@msg(message.33)
		@comment("...continued into Cmd 8")
		@goto(30)
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@goto(1)
		@look
	@endif
background.9
	@if @not @isroom(12) @then
		@comment("NO TREAD")
		@set(value.flag.14,false)
	@endif
background.10
	@comment("night?")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.1))
	@set(value.counter.1,@get(temp.swap))
	@if @gt(value.counter,0) @then
		@subto(value.counter,1)
	@endif
	@comment("continue")
	@comment("...continued into Cmd 11")
	@if @le(value.counter,30) @and @isfalse(@get(value.flag.2)) @and @isfalse(@get(value.flag.17)) @and @isfalse(@get(value.flag.18)) @then
		@msg(message.5)
	@endif
	@comment("...continued into Cmd 12")
	@if @le(value.counter,0) @and @isfalse(@get(value.flag.2)) @and @isfalse(@get(value.flag.17)) @and @isfalse(@get(value.flag.18)) @then
		@set(value.flag.2,true)
		@msg(message.6)
		@set(value.flag.dark,true)
		@look
	@endif
	@comment("...continued into Cmd 13")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.1))
	@set(value.counter.1,@get(temp.swap))
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.3))
	@set(value.counter.3,@get(temp.swap))
	@if @gt(value.counter,0) @then
		@subto(value.counter,1)
	@endif
	@comment("...continued into Cmd 14")
	@if @le(value.counter,0) @and @isfalse(@get(value.flag.6)) @then
		@sendto(5,15)
		@msg(message.7)
		@set(value.flag.6,true)
	@endif
	@comment("...continued into Cmd 15")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.3))
	@set(value.counter.3,@get(temp.swap))
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.2))
	@set(value.counter.2,@get(temp.swap))
	@if @gt(value.counter,0) @then
		@subto(value.counter,1)
	@endif
	@comment("...continued into Cmd 16")
	@if @le(value.counter,15) @and @ge(value.counter,0) @and @isfalse(@get(value.flag.4)) @and @not @isroom(13) @and @isfalse(@get(value.flag.19)) @then
		@msg(message.8)
	@endif
	@comment("...continued into Cmd 17")
	@if @isfalse(@get(value.flag.4)) @and @le(value.counter,0) @and @isfalse(@get(value.flag.19)) @then
		@msg(message.9)
		@set(value.flag.4,true)
		@set(value.counter,85)
	@endif
	@comment("...continued into Cmd 18")
	@if @istrue(@get(value.flag.4)) @and @le(value.counter,50) @and @istrue(@get(value.flag.5)) @then
		@set(value.flag.4,false)
		@set(value.flag.19,true)
		@msg(message.10)
	@endif
	@comment("...continued into Cmd 19")
	@if @istrue(@get(value.flag.4)) @and @le(value.counter,0) @and @here(31) @and @not @isroom(3) @then
		@msg(message.56)
		@msg(message.66)
		@msg(message.11)
		@set(value.flag.dark,false)
		@goto(34)
	@endif
	@comment("...continued into Cmd 20")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.2))
	@set(value.counter.2,@get(temp.swap))
background.21
	@if @carry(25) @then
		@comment("NO TREAD")
		@set(value.flag.14,false)
	@endif
background.22
	@if @carry(28) @then
		@comment("NO TREAD")
		@set(value.flag.14,false)
	@endif
