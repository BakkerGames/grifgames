command.1.32
	@comment("Cmd 120 - go curt")
	@if @isroom(6) @and @true(@get(value.flag.6)) @then
		@comment("OUT NO AIR")
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@drop(1)
		@look
		@set(value.flag.2,true)
		@comment("...continued into Cmd 121")
	@elseif @here(1) @and @nowhere(23) @then
		@comment("IN GOOD AIR")
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@look
		@set(value.flag.2,false)
		@msg(message.3)
		@comment("...continued into Cmd 122")
	@elseif @isroom(6) @and @false(@get(value.flag.6)) @then
		@comment("OUT AIR")
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@drop(1)
		@look
		@set(value.flag.2,false)
		@comment("...continued into Cmd 126")
	@elseif @here(1) @and @somewhere(23) @then
		@comment("IN HOSE")
		@msg(message.50)
		@msg(message.18)
		@set(value.flag.dark,false)
		@goto(35)
	@endif
