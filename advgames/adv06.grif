// adv06.grif - GRIF format
@atstartroom(x)
	@eq(@get(item.$x.location),@get(value.startroom))
@carry(x)
	@eq(@get(item.$x.location),@inv)
@drop(x)
	@sendto($x,@room)
@goto(x)
	@set(value.room,$x)
@here(x)
	@eq(@get(item.$x.location),@room)
@herecarry(x)
	@if @eq(@get(item.$x.location),@room) @or @eq(@get(item.$x.location),@inv) @then
		@write("true")
	@else
		@write("false")
	@endif
@inv
	-1
@invcount
	@set(temp.count,0)
	@for(x,1,@get(system.itemcount))
		@if @carry($x) @then
			@addto(temp.count,1)
		@endif
	@endfor
	@write(@get(temp.count))
@isroom(x)
	@eq(@room,$x)
@look
	@debug(@concat("### ROOM #",@room,"\n"))
	@if @true(@get(value.flag.dark)) @and @not @herecarry(9) @then
		@msg(message.cant_see)
	@else
		@script(script.before_look)
		@msg(@concat("room.",@room,".longdesc"))
		@nl
		@msg(message.obvious_exits)
		@msg(@concat("room.",@room,".exitlist"))
		@set(temp.found,false)
		@for(i,0,@get(system.itemcount))
			@if @here($i) @then
				@if @false(@get(temp.found)) @then
					@nl
					@msg(message.also_see)
					@set(temp.found,true)
				@endif
				@debug(@concat("### ITEM #",$i,"\n"))
				@msg(item.$i.longdesc)
			@endif
		@endfor
	@endif
@modmessages
	@foreachkey(i,"modmsg.")
		@nl
		@msg(modmsg.$i)
	@endforeachkey
@nowhere(x)
	@eq(@get(item.$x.location),0)
@picture(x)
	@setoutchannel("#PICTURE;",$x)
@quit
	@setoutchannel("#GAMEOVER;")
@room
	@get(value.room)
@sendto(x,y)
	@set(item.$x.location,$y)
@sleep(x)
	@setoutchannel("#SLEEP;",$x)
@somewhere(x)
	@ne(@get(item.$x.location),0)
@take(x)
	@sendto($x,@inv)
background.2
	@if @isroom(14) @and @not @carry(45) @then
		@comment("JOVIAN SQUASH")
		@msg(message.63)
		@msg(message.64)
		@msg(message.67)
		@quit
	@endif
background.3
	@if @here(18) @then
		@comment("AIR GOOD")
		@set(value.flag.2,false)
	@endif
background.4
	@if @isroom(14) @and @not @carry(46) @then
		@comment("JOVIAN SQUASH")
		@msg(message.63)
		@msg(message.64)
		@msg(message.67)
		@quit
	@endif
background.5
	@if @false(@get(value.flag.1)) @then
		@comment("INTRO")
		@set(value.flag.1,true)
		@comment("continue")
		@set(value.flag.5,true)
		@set(value.flag.6,true)
		@comment("...continued into Cmd 6")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@set(value.counter,28)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@msg(message.1)
		@comment("...continued into Cmd 7")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
		@set(value.counter,110)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
		@goto(6)
		@comment("...continued into Cmd 8")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@set(value.counter,2)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.3))
		@set(value.counter.3,@get(temp.swap))
		@set(temp.swap,@get(value.room))
		@set(value.room,@get(value.locationswap))
		@set(value.locationswap,@get(temp.swap))
		@comment("...continued into Cmd 9")
		@goto(1)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
		@set(value.counter,20)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
	@endif
background.10
	@if @herecarry(7) @then
		@comment("AIR SUIT")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 11")
		@if @le(value.counter,27) @then
			@msg(message.25)
		@endif
		@comment("...continued into Cmd 12")
		@if @le(value.counter,0) @then
			@msg(message.11)
			@set(value.flag.dark,false)
			@goto(35)
		@endif
		@comment("...continued into Cmd 13")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.1))
		@set(value.counter.1,@get(temp.swap))
	@endif
background.14
	@if @carry(44) @and @somewhere(46) @and @not @carry(46) @then
		@comment("ACT BELT")
		@take(46)
	@endif
background.15
	@if @here(44) @and @somewhere(46) @and @not @here(46) @then
		@comment("ACT BELT")
		@drop(46)
	@endif
background.16
	@if @rand(30) @and @carry(30) @then
		@comment("HOUND ATTACKS")
		@msg(message.45)
		@set(value.flag.dark,false)
		@goto(35)
	@endif
background.17
	@if @rand(15) @and @here(30) @then
		@comment("HOUND ATTACKS")
		@msg(message.45)
		@set(value.flag.dark,false)
		@goto(35)
	@endif
background.18
	@if @somewhere(31) @then
		@comment("HOUND WAKES")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 19")
		@if @le(value.counter,0) @then
			@swap(item.31.location,item.30.location)
		@endif
		@comment("...continued into Cmd 20")
		@if @herecarry(30) @then
			@msg(message.46)
		@endif
		@comment("...continued into Cmd 21")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.4))
		@set(value.counter.4,@get(temp.swap))
	@endif
background.22
	@if @true(@get(value.flag.4)) @then
		@comment("PHASER FIRED")
		@comment("continue")
		@set(value.flag.4,false)
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.2))
		@set(value.counter.2,@get(temp.swap))
		@comment("...continued into Cmd 23")
		@if @false(@get(value.flag.3)) @then
			@subto(value.counter,4)
			@set(temp.swap,@get(value.counter))
			@set(value.counter,@get(value.counter.2))
			@set(value.counter.2,@get(temp.swap))
		@endif
		@comment("...continued into Cmd 24")
		@if @true(@get(value.flag.3)) @then
			@subto(value.counter,7)
			@set(temp.swap,@get(value.counter))
			@set(value.counter,@get(value.counter.2))
			@set(value.counter.2,@get(temp.swap))
		@endif
		@comment("...continued into Cmd 25")
	@endif
background.26
	@if @true(@get(value.flag.2)) @and @not @carry(7) @then
		@comment("DIE NO AIR")
		@msg(message.10)
		@msg(message.8)
		@msg(message.7)
		@quit
	@endif
background.28
	@comment("EMPTY PHASER")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.2))
	@set(value.counter.2,@get(temp.swap))
	@comment("continue")
	@comment("...continued into Cmd 29")
	@if @le(value.counter,0) @and @nowhere(11) @then
		@swap(item.11.location,item.10.location)
	@endif
	@comment("...continued into Cmd 30")
	@set(temp.swap,@get(value.counter))
	@set(value.counter,@get(value.counter.2))
	@set(value.counter.2,@get(temp.swap))
	@comment("...continued into Cmd 31")
background.32
	@if @here(35) @and @here(28) @then
		@comment("DROP ROD")
		@swap(item.28.location,item.37.location)
		@sendto(35,0)
		@msg(message.51)
		@look
	@endif
background.33
	@if @here(30) @then
		@comment("ICE HOUND")
		@comment("continue")
		@comment("...continued into Cmd 34")
		@if @isroom(18) @then
			@sendto(38,20)
			@sendto(30,0)
			@msg(message.53)
		@endif
		@comment("...continued into Cmd 35")
		@if @isroom(19) @then
			@sendto(38,20)
			@sendto(30,0)
			@msg(message.53)
		@endif
		@comment("...continued into Cmd 36")
		@if @isroom(20) @then
			@sendto(38,20)
			@sendto(30,0)
			@msg(message.53)
		@endif
		@comment("...continued into Cmd 37")
		@if @isroom(10) @then
			@sendto(38,20)
			@sendto(30,0)
			@msg(message.53)
		@endif
		@comment("...continued into Cmd 38")
		@if @nowhere(30) @then
			@sendto(30,24)
		@endif
	@endif
background.39
	@if @isroom(35) @then
		@comment("DEAD!")
		@quit
	@endif
background.40
	@if @true(@get(value.flag.9)) @then
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
		@if @gt(value.counter,0) @then
			@subto(value.counter,1)
		@endif
		@comment("continue")
		@comment("...continued into Cmd 41")
		@if @le(value.counter,1) @then
			@set(value.flag.9,false)
			@set(value.flag.10,true)
		@endif
		@comment("...continued into Cmd 42")
		@if @carry(52) @and @carry(51) @then
			@set(value.flag.dark,false)
			@drop(55)
			@look
		@endif
		@comment("...continued into Cmd 43")
		@set(temp.swap,@get(value.counter))
		@set(value.counter,@get(value.counter.5))
		@set(value.counter.5,@get(temp.swap))
	@endif
background.44
	@if @carry(52) @and @false(@get(value.flag.9)) @and @false(@get(value.flag.15)) @then
		@comment("WEAR OFF GOGGLES")
		@set(value.flag.dark,true)
		@look
	@endif
background.intro
	@if @false(@get(system.introdone)) @then
		@modmessages
		@look
		@set(system.introdone,true)
	@endif
command.1.1
	@if @gt(@get(@concat("room.",@room,".exit.n")),0) @then
		@goto(@get(@concat("room.",@room,".exit.n")))
		@look
	@else
		@msg(message.cant_go)
	@endif
