command.1.10
	@comment("Cmd 55 - go doo")
	@if @here(17) @and @isroom(4) @then
		@goto(6)
		@set(value.flag.dark,true)
		@look
		@comment("...continued into Cmd 56")
	@elseif @here(16) @and @isroom(4) @then
		@msg(message.13)
		@comment("...continued into Cmd 67")
	@elseif @isroom(5) @and @true(@get(value.flag.6)) @then
		@msg(message.15)
		@comment("...continued into Cmd 73")
	@elseif @isroom(6) @and @here(25) @then
