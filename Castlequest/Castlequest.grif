script.lamp_moves
	@comment("lamp moves")
	@if @eq(@get(value.lamp),1) @or @eq(@get(value.lamp),2) @then
		@addto(value.lmove,1)
		@debug(@concat("\n### LAMP MOVES = ",@get(value.lmove)))
		@if @eq(@get(value.lamp),1) @and @ge(@get(value.lmove),@get(value.lampdim)) @then
			@set(value.lamp,2)
			@msg(message.1083)
			@if @carry(1) @and @carry(21) @then
				@msg(message.1085)
				@sendto(1,0)
				@set(value.lmove,0)
				@set(value.lamp,1)
			@endif
		@elseif @eq(@get(value.lamp),2) @and @ge(@get(value.lmove),@get(value.lampout)) @then
			@set(value.lamp,3)
			@msg(message.1009)
			@if @dark @then
				@msg(message.1064)
			@endif
		@endif
	@endif
